# ═══════════════════════════════════════════════════════
#  ecom-final — .gitignore
# ═══════════════════════════════════════════════════════

# ── Environment & Secrets ────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual environments ─────────────────────────────
.venv/
venv/
ENV/
env/
.env.bak

# ── Django ───────────────────────────────────────────
*.sqlite3
*.sqlite3-journal
staticfiles/
mediafiles/
media/
local_settings.py

# ── Docker ───────────────────────────────────────────
# Không ignore docker-compose.yml — cần commit
# Ignore volumes / runtime data được tạo local

# ── Logs ─────────────────────────────────────────────
*.log
logs/
*.log.*

# ── IDE / Editor ─────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Node (nếu dùng build tool cho frontend) ──────────
node_modules/
npm-debug.log*
yarn-error.log*
.npm

# ── AI model cache (lớn, download khi chạy) ──────────
ai-service/models/
ai-service/data/faiss_index/
ai-service/data/chroma_db/
# Behavior store SQLite + vector index + LSTM snapshot (runtime data)
ai-service/ai_data/
*.bin
*.safetensors
*.gguf

# ── Test artifacts ────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ── Jupyter ───────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Claude Code internal ──────────────────────────────
.claude/

# ── Backup files ──────────────────────────────────────
*.bak
*.orig
*.backup
