# ═══════════════════════════════════════════════════
#  ecom-final — Environment Variables (mẫu)
#  Sao chép thành .env rồi điền giá trị thật:
#    cp .env.example .env
# ═══════════════════════════════════════════════════

# ── Django Settings ──────────────────────────────────
DEBUG=False
SECRET_KEY=thay-bang-chuoi-ngau-nhien-dai-it-nhat-50-ky-tu

# ── MySQL (User, Cart, Payment, Shipping services) ───
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=ecom
MYSQL_PASSWORD=ecom_password

# ── PostgreSQL (Product, Order services) ─────────────
POSTGRES_USER=ecom
POSTGRES_PASSWORD=ecom_password

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Neo4j (AI service — Knowledge Graph) ─────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ── OpenAI API (tuỳ chọn — AI service) ───────────────
# Để trống nếu không dùng, service sẽ dùng model local
OPENAI_API_KEY=
